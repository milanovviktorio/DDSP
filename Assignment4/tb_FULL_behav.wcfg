      <obj_property name="ObjectShortName">sine_val[7:0]</obj_property>
      <obj_property name="WaveformStyle">STYLE_ANALOG</obj_property>
      <obj_property name="CellHeight">100</obj_property>
   </wvobject>
   <wvobject fp_name="/tb_FULL/DUT/AVG/avg_out" type="array">
      <obj_property name="ElementShortName">avg_out[7:0]</obj_property>
      <obj_property name="ObjectShortName">avg_out[7:0]</obj_property>
      <obj_property name="WaveformStyle">STYLE_ANALOG</obj_property>
